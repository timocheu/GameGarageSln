@model GameGarage.Models.Game

@{
    ViewData["Title"] = "Add New Game";
    Layout = "_AdminLayout";
}

<div class="p-8 text-gray-200 mt-8">
    <div class="mb-8 flex justify-between items-center">
        <div>
            <h1 class="text-2xl font-bold text-white tracking-tight">Create Game Entry</h1>
            <p class="text-gray-500 text-sm">Fill in the details to add a new title to the Game Garage catalog.</p>
        </div>
        <a asp-action="Index"
            class="text-sm font-medium text-gray-400 hover:text-orange-500 transition-colors flex items-center gap-2">
            <i class="fas fa-arrow-left"></i> Back to Inventory
        </a>
    </div>

    <div class="flex flex-col items-center">
        <form asp-action="Create" class="max-w-5xl">
            <div asp-validation-summary="ModelOnly"
                class="mb-6 p-4 bg-red-500/10 border border-red-500/20 rounded-xl text-red-500 text-sm"></div>

            <div class="grid grid-cols-12 gap-6">

                <div class="col-span-12 lg:col-span-8 space-y-6">
                    <div class="bg-[#12161f] p-6 rounded-3xl border border-gray-800 shadow-xl">
                        <h3
                            class="text-orange-500 font-bold mb-6 flex items-center gap-2 uppercase tracking-widest text-xs">
                            <i class="fas fa-info-circle"></i> General Information
                        </h3>

                        <div class="space-y-4">
                            <div>
                                <label asp-for="Name"
                                    class="block text-xs font-semibold text-gray-500 uppercase mb-2 ml-1">Game Title</label>
                                <input asp-for="Name"
                                    class="w-full bg-[#1a1f29] border border-gray-700 rounded-xl py-3 px-4 focus:ring-2 focus:ring-orange-600/50 focus:border-orange-500 transition-all outline-none"
                                    placeholder="e.g. Black Myth: Wukong" />
                                <span asp-validation-for="Name" class="text-red-500 text-xs mt-1 block"></span>
                            </div>

                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <label asp-for="ReleaseDate"
                                        class="block text-xs font-semibold text-gray-500 uppercase mb-2 ml-1">Release
                                        Date</label>
                                    <input asp-for="ReleaseDate" type="date"
                                        class="w-full bg-[#1a1f29] border border-gray-700 rounded-xl py-3 px-4 focus:ring-2 focus:ring-orange-600/50 focus:border-orange-500 transition-all outline-none" />
                                    <span asp-validation-for="ReleaseDate" class="text-red-500 text-xs mt-1 block"></span>
                                </div>
                                <div>
                                    <label asp-for="Price"
                                        class="block text-xs font-semibold text-gray-500 uppercase mb-2 ml-1">Price
                                        (USD)</label>
                                    <div class="relative">
                                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500">$</span>
                                        <input asp-for="Price"
                                            class="w-full bg-[#1a1f29] border border-gray-700 rounded-xl py-3 pl-8 pr-4 focus:ring-2 focus:ring-orange-600/50 focus:border-orange-500 transition-all outline-none"
                                            placeholder="0.00" />
                                    </div>
                                    <span asp-validation-for="Price" class="text-red-500 text-xs mt-1 block"></span>
                                </div>
                            </div>

                            <div>
                                <label asp-for="AboutTheGame"
                                    class="block text-xs font-semibold text-gray-500 uppercase mb-2 ml-1">About the
                                    Game</label>
                                <textarea asp-for="AboutTheGame" rows="4"
                                    class="w-full bg-[#1a1f29] border border-gray-700 rounded-xl py-3 px-4 focus:ring-2 focus:ring-orange-600/50 focus:border-orange-500 transition-all outline-none resize-none"
                                    placeholder="Describe the journey..."></textarea>
                                <span asp-validation-for="AboutTheGame" class="text-red-500 text-xs mt-1 block"></span>
                            </div>
                        </div>
                    </div>

                    <div class="bg-[#12161f] p-6 rounded-3xl border border-gray-800 shadow-xl">
                        <h3
                            class="text-orange-500 font-bold mb-6 flex items-center gap-2 uppercase tracking-widest text-xs">
                            <i class="fas fa-images"></i> Media Assets
                        </h3>
                        <div class="space-y-4">
                            <div>
                                <label asp-for="HeaderImage"
                                    class="block text-xs font-semibold text-gray-500 uppercase mb-2 ml-1">Header Image
                                    URL</label>
                                <input asp-for="HeaderImage"
                                    class="w-full bg-[#1a1f29] border border-gray-700 rounded-xl py-3 px-4 focus:ring-2 focus:ring-orange-600/50 focus:border-orange-500 transition-all outline-none"
                                    placeholder="https://..." />
                            </div>
                            <div>
                                <label asp-for="Screenshots"
                                    class="block text-xs font-semibold text-gray-500 uppercase mb-2 ml-1">Screenshots (Comma
                                    separated)</label>
                                <input asp-for="Screenshots"
                                    class="w-full bg-[#1a1f29] border border-gray-700 rounded-xl py-3 px-4 focus:ring-2 focus:ring-orange-600/50 focus:border-orange-500 transition-all outline-none"
                                    placeholder="url1, url2, url3" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-span-12 lg:col-span-4 space-y-6">

                    <div class="bg-[#12161f] p-6 rounded-3xl border border-gray-800 shadow-xl">
                        <h3
                            class="text-orange-500 font-bold mb-6 flex items-center gap-2 uppercase tracking-widest text-xs">
                            <i class="fas fa-desktop"></i> Support Platforms
                        </h3>
                        <div class="space-y-3">
                            <label
                                class="flex items-center justify-between p-3 bg-[#1a1f29] rounded-xl cursor-pointer border border-transparent hover:border-gray-600 transition-all">
                                <span class="text-sm flex items-center gap-3"><i class="fab fa-windows text-blue-400"></i>
                                    Windows</span>
                                <input type="checkbox" id="checkWindows"
                                    class="platform-toggle w-5 h-5 rounded border-gray-700 bg-gray-800 text-orange-600 focus:ring-orange-500"
                                    @(Model?.Windows == "True" ? "checked" : "") />
                                <input type="hidden" asp-for="Windows" id="valWindows"
                                    value="@(Model?.Windows ?? "False")" />
                            </label>

                            <label
                                class="flex items-center justify-between p-3 bg-[#1a1f29] rounded-xl cursor-pointer border border-transparent hover:border-gray-600 transition-all">
                                <span class="text-sm flex items-center gap-3"><i class="fab fa-apple text-white"></i>
                                    macOS</span>
                                <input type="checkbox" id="checkMac"
                                    class="platform-toggle w-5 h-5 rounded border-gray-700 bg-gray-800 text-orange-600 focus:ring-orange-500"
                                    @(Model?.Mac == "True" ? "checked" : "") />
                                <input type="hidden" asp-for="Mac" id="valMac" value="@(Model?.Mac ?? "False")" />
                            </label>

                            <label
                                class="flex items-center justify-between p-3 bg-[#1a1f29] rounded-xl cursor-pointer border border-transparent hover:border-gray-600 transition-all">
                                <span class="text-sm flex items-center gap-3"><i class="fab fa-linux text-orange-400"></i>
                                    Linux</span>
                                <input type="checkbox" id="checkLinux"
                                    class="platform-toggle w-5 h-5 rounded border-gray-700 bg-gray-800 text-orange-600 focus:ring-orange-500"
                                    @(Model?.Linux == "True" ? "checked" : "") />
                                <input type="hidden" asp-for="Linux" id="valLinux" value="@(Model?.Linux ?? "False")" />
                            </label>
                        </div>
                    </div>


                    <div class="bg-[#12161f] p-6 rounded-3xl border border-gray-800 shadow-xl">
                        <h3
                            class="text-orange-500 font-bold mb-6 flex items-center gap-2 uppercase tracking-widest text-xs">
                            <i class="fas fa-tags"></i> Taxonomy
                        </h3>
                        <div class="space-y-4">
                            <div>
                                <label asp-for="Developers"
                                    class="block text-xs font-semibold text-gray-500 uppercase mb-2 ml-1">Developers</label>
                                <input asp-for="Developers"
                                    class="w-full bg-[#1a1f29] border border-gray-700 rounded-xl py-2 px-4 text-sm outline-none focus:border-orange-500" />
                            </div>
                            <div>
                                <label asp-for="Publishers"
                                    class="block text-xs font-semibold text-gray-500 uppercase mb-2 ml-1">Publishers</label>
                                <input asp-for="Publishers"
                                    class="w-full bg-[#1a1f29] border border-gray-700 rounded-xl py-2 px-4 text-sm outline-none focus:border-orange-500" />
                            </div>
                            <div>
                                <label asp-for="Tags"
                                    class="block text-xs font-semibold text-gray-500 uppercase mb-2 ml-1">Tags</label>
                                <input asp-for="Tags"
                                    class="w-full bg-[#1a1f29] border border-gray-700 rounded-xl py-2 px-4 text-sm outline-none focus:border-orange-500"
                                    placeholder="RPG, Action, Soulslike" />
                            </div>
                        </div>
                    </div>

                    <button type="submit"
                        class="w-full bg-orange-600 hover:bg-orange-500 text-white font-bold py-4 rounded-2xl shadow-lg shadow-orange-600/20 transition-all flex items-center justify-center gap-2">
                        <i class="fas fa-save"></i> Save Game to Store
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Synchronize the checkbox state with the hidden string input
        document.querySelectorAll('.platform-toggle').forEach(checkbox => {
            checkbox.addEventListener('change', function () {
                // Find the hidden input immediately following the checkbox
                const hiddenInput = this.nextElementSibling;
                hiddenInput.value = this.checked ? "True" : "False";
            });
        });
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}