@model GameGarage.Models.Game

@{
    ViewData["Title"] = "Delete Game";
    Layout = "_AdminLayout";
}

<div class="p-8 text-gray-200 flex items-center justify-center">
    <div class="max-w-2xl w-full">
        
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-20 h-20 bg-red-500/10 border border-red-500/20 rounded-full mb-4">
                <i class="fas fa-exclamation-triangle text-3xl text-red-500"></i>
            </div>
            <h1 class="text-3xl font-black text-white tracking-tight uppercase">Remove Game?</h1>
            <p class="text-gray-500 mt-2">This action is permanent and cannot be undone.</p>
        </div>

        <div class="bg-[#12161f] rounded-[2.5rem] border border-gray-800 overflow-hidden shadow-2xl mb-8">
            <div class="relative h-48">
                <img src="@Model.HeaderImage" class="w-full h-full object-cover opacity-50 grayscale hover:grayscale-0 transition-all duration-500" alt="Preview" />
                <div class="absolute inset-0 bg-gradient-to-t from-[#12161f] to-transparent"></div>
                <div class="absolute bottom-6 left-8">
                    <h2 class="text-2xl font-bold text-white uppercase tracking-tighter">@Model.Name</h2>
                    <p class="text-xs text-orange-500 font-bold tracking-widest uppercase mt-1">ID: #@Model.Id</p>
                </div>
            </div>

            <div class="p-8 grid grid-cols-2 gap-6 border-t border-gray-800/50">
                <div>
                    <h4 class="text-[10px] font-black text-gray-600 uppercase tracking-[0.2em] mb-1">Developer</h4>
                    <p class="text-sm font-semibold text-gray-300">@Model.Developers</p>
                </div>
                <div>
                    <h4 class="text-[10px] font-black text-gray-600 uppercase tracking-[0.2em] mb-1">Price</h4>
                    <p class="text-sm font-semibold text-gray-300">$@Model.Price</p>
                </div>
                <div class="col-span-2">
                    <h4 class="text-[10px] font-black text-gray-600 uppercase tracking-[0.2em] mb-1">About</h4>
                    <p class="text-xs text-gray-500 line-clamp-2 italic">"@Model.AboutTheGame"</p>
                </div>
            </div>
        </div>

        <form asp-action="Delete" class="flex flex-col gap-4">
            <input type="hidden" asp-for="Id" />
            
            <button type="submit" class="group relative w-full bg-red-600 hover:bg-red-500 text-white font-bold py-5 rounded-2xl shadow-lg shadow-red-900/20 transition-all overflow-hidden">
                <span class="relative z-10 flex items-center justify-center gap-2">
                    <i class="fas fa-trash-alt"></i> Permanently Delete Game
                </span>
                <div class="absolute inset-0 bg-white/10 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
            </button>

            <a asp-action="Index" class="w-full text-center py-4 text-sm font-bold text-gray-500 hover:text-white transition-colors">
                Cancel, Keep this entry
            </a>
        </form>

    </div>
</div>