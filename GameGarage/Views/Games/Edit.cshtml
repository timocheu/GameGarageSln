@model GameGarage.Models.Game

@{
    ViewData["Title"] = "Edit Game";
    Layout = "_AdminLayout";
}

<div class="p-8 text-gray-200 mt-8">
    <div class="mb-8 flex justify-between items-center">
        <div>
            <h1 class="text-2xl font-bold text-white tracking-tight">Modify Game</h1>
            <p class="text-gray-500 text-sm">Updating entry for <span
                    class="text-orange-500 font-semibold">@Model.Name</span> (ID: @Model.Id)</p>
        </div>
        <a asp-action="Index"
            class="text-sm font-medium text-gray-400 hover:text-orange-500 transition-colors flex items-center gap-2">
            <i class="fas fa-arrow-left"></i> Back to Inventory
        </a>
    </div>

    <div class="flex flex-col items-center">
    <form asp-action="Edit" class="max-w-6xl">
        <div asp-validation-summary="ModelOnly"
            class="mb-6 p-4 bg-red-500/10 border border-red-500/20 rounded-xl text-red-500 text-sm"></div>
        <input type="hidden" asp-for="Id" />

        <div class="grid grid-cols-12 gap-6">

            <div class="col-span-12 lg:col-span-8 space-y-6">
                <div class="bg-[#12161f] p-6 rounded-3xl border border-gray-800 shadow-xl">
                    <h3
                        class="text-orange-500 font-bold mb-6 flex items-center gap-2 uppercase tracking-widest text-xs">
                        <i class="fas fa-edit"></i> Core Information
                    </h3>

                    <div class="space-y-4">
                        <div>
                            <label asp-for="Name"
                                class="block text-xs font-semibold text-gray-500 uppercase mb-2 ml-1">Title</label>
                            <input asp-for="Name"
                                class="w-full bg-[#1a1f29] border border-gray-700 rounded-xl py-3 px-4 focus:ring-2 focus:ring-orange-600/50 focus:border-orange-500 outline-none" />
                            <span asp-validation-for="Name" class="text-red-500 text-xs mt-1 block"></span>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label asp-for="ReleaseDate"
                                    class="block text-xs font-semibold text-gray-500 uppercase mb-2 ml-1">Release
                                    Date</label>
                                <input asp-for="ReleaseDate"
                                    class="w-full bg-[#1a1f29] border border-gray-700 rounded-xl py-3 px-4 focus:ring-2 focus:ring-orange-600/50 outline-none" />
                            </div>
                            <div>
                                <label asp-for="Price"
                                    class="block text-xs font-semibold text-gray-500 uppercase mb-2 ml-1">Price</label>
                                <input asp-for="Price"
                                    class="w-full bg-[#1a1f29] border border-gray-700 rounded-xl py-3 px-4 focus:ring-2 focus:ring-orange-600/50 outline-none" />
                            </div>
                        </div>

                        <div>
                            <label asp-for="AboutTheGame"
                                class="block text-xs font-semibold text-gray-500 uppercase mb-2 ml-1">About</label>
                            <textarea asp-for="AboutTheGame" rows="5"
                                class="w-full bg-[#1a1f29] border border-gray-700 rounded-xl py-3 px-4 focus:ring-2 focus:ring-orange-600/50 outline-none resize-none"></textarea>
                        </div>
                    </div>
                </div>

                <div class="bg-[#12161f] p-6 rounded-3xl border border-gray-800 shadow-xl">
                    <h3
                        class="text-orange-500 font-bold mb-6 flex items-center gap-2 uppercase tracking-widest text-xs">
                        <i class="fas fa-photo-video"></i> Media Assets
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-4">
                            <div>
                                <label asp-for="HeaderImage"
                                    class="block text-xs font-semibold text-gray-500 uppercase mb-2 ml-1">Header Image
                                    URL</label>
                                <input asp-for="HeaderImage" id="headerInput"
                                    class="w-full bg-[#1a1f29] border border-gray-700 rounded-xl py-3 px-4 text-sm outline-none focus:border-orange-500" />
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-gray-500 uppercase mb-2 ml-1">Screenshots
                                    (One URL per line)</label>
                                @* Use string.Join to put the List back into the textarea for editing *@
                                <textarea name="Screenshots" rows="5"
                                    class="w-full bg-[#1a1f29] border border-gray-700 rounded-xl py-3 px-4 text-sm outline-none focus:border-orange-500">@string.Join(Environment.NewLine, Model.Screenshots ?? new List<string>())</textarea>
                                <p class="text-[10px] text-gray-600 mt-2">Your DbContext will handle the conversion back
                                    to a List.</p>
                            </div>
                        </div>
                        <div
                            class="rounded-2xl border border-gray-800 bg-[#0b0e14] overflow-hidden flex flex-col items-center justify-center p-2">
                            <p class="text-[10px] text-gray-600 uppercase font-bold mb-2">Live Header Preview</p>
                            <img id="headerPreview" src="@Model.HeaderImage"
                                class="w-full h-40 object-cover rounded-xl border border-gray-800 shadow-inner"
                                onerror="this.src='https://placehold.co/600x400/1a1f29/white?text=Invalid+URL'" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-span-12 lg:col-span-4 space-y-6">
                <div
                    class="bg-[#12161f] p-6 rounded-3xl border border-orange-900/20 shadow-xl bg-gradient-to-br from-[#12161f] to-[#1a1614]">
                    <button type="submit"
                        class="w-full bg-orange-600 hover:bg-orange-500 text-white font-bold py-4 rounded-2xl shadow-lg shadow-orange-900/40 transition-all flex items-center justify-center gap-2">
                        <i class="fas fa-check-circle"></i> Save Changes
                    </button>
                </div>

                <div class="bg-[#12161f] p-6 rounded-3xl border border-gray-800 shadow-xl">
                    <h3
                        class="text-orange-500 font-bold mb-6 flex items-center gap-2 uppercase tracking-widest text-xs">
                        <i class="fas fa-laptop-code"></i> Platforms
                    </h3>
                    <div class="space-y-2">
                        @foreach (var platform in new[] { "Windows", "Mac", "Linux" })
                        {
                            var currentVal = platform == "Windows" ? Model.Windows : platform == "Mac" ? Model.Mac :
                            Model.Linux;
                            <label
                                class="flex items-center justify-between p-3 bg-[#1a1f29] rounded-xl border border-transparent hover:border-gray-700 cursor-pointer group transition-all">
                                <span
                                    class="text-sm font-semibold text-gray-400 group-hover:text-white transition-colors">@platform</span>
                                <input type="checkbox"
                                    class="platform-check w-5 h-5 rounded border-gray-700 bg-gray-800 text-orange-600 focus:ring-orange-500"
                                    @(currentVal == "True" ? "checked" : "") data-target="val@(platform)" />
                                <input type="hidden" name="@platform" id="val@(platform)"
                                    value="@(currentVal ?? "False")" />
                            </label>
                        }
                    </div>
                </div>

                <div class="bg-[#12161f] p-6 rounded-3xl border border-gray-800 shadow-xl">
                    <h3
                        class="text-orange-500 font-bold mb-6 flex items-center gap-2 uppercase tracking-widest text-xs">
                        <i class="fas fa-tags"></i> Taxonomy
                    </h3>
                    <div class="space-y-4">
                        <div>
                            <label asp-for="Developers"
                                class="block text-xs font-semibold text-gray-500 uppercase mb-2 ml-1">Developers</label>
                            <input asp-for="Developers"
                                class="w-full bg-[#1a1f29] border border-gray-700 rounded-xl py-2 px-4 text-sm outline-none focus:border-orange-500" />
                        </div>
                        <div>
                            <label asp-for="Publishers"
                                class="block text-xs font-semibold text-gray-500 uppercase mb-2 ml-1">Publishers</label>
                            <input asp-for="Publishers"
                                class="w-full bg-[#1a1f29] border border-gray-700 rounded-xl py-2 px-4 text-sm outline-none focus:border-orange-500" />
                        </div>
                        <div>
                            <label asp-for="Categories"
                                class="block text-xs font-semibold text-gray-500 uppercase mb-2 ml-1">Genre / Categories</label>
                            <input asp-for="Categories"
                                class="w-full bg-[#1a1f29] border border-gray-700 rounded-xl py-2 px-4 text-sm outline-none focus:border-orange-500" />
                        </div>
                        <div>
                            <label asp-for="Tags"
                                class="block text-xs font-semibold text-gray-500 uppercase mb-2 ml-1">Tags (Comma
                                Sep)</label>
                            <input asp-for="Tags"
                                class="w-full bg-[#1a1f29] border border-gray-700 rounded-xl py-2 px-4 text-sm outline-none focus:border-orange-500" />
                        </div>
                        <div>
                            <label asp-for="Notes"
                                class="block text-xs font-semibold text-gray-500 uppercase mb-2 ml-1">Admin
                                Notes</label>
                            <input asp-for="Notes"
                                class="w-full bg-[#1a1f29] border border-gray-700 rounded-xl py-2 px-4 text-sm outline-none focus:border-orange-500" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
    </div>
</div>

@section Scripts {
    <script>
        // Real-time Header Preview
        const headerInput = document.getElementById('headerInput');
        const headerPreview = document.getElementById('headerPreview');

        headerInput.addEventListener('input', (e) => {
            if (e.target.value) {
                headerPreview.src = e.target.value;
            }
        });

        // Platform String Logic (True/False)
        document.querySelectorAll('.platform-check').forEach(box => {
            box.addEventListener('change', function () {
                const targetId = this.getAttribute('data-target');
                document.getElementById(targetId).value = this.checked ? "True" : "False";
            });
        });
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}