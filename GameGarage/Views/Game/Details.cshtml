@model Game

@if (Model == null)
{
	<div class="flex flex-col items-center justify-center min-h-screen space-y-6">

		<h1 class="text-4xl font-bold tracking-tight text-white">Game not found</h1>

		<p class="text-sm" style="color:#5e809e">
			The game you are looking for does not exist or has been removed.
		</p>

		<a href="/"
		   class="px-6 py-2 text-white text-sm font-semibold uppercase tracking-wider transition-all"
		   style="background:#eb5e28; border-radius:9px; box-shadow:0 4px 18px rgba(235,94,40,0.4);">
			Back to Home
		</a>

	</div>
}
else
{
    ViewBag.Title = $"{Model.Name} on GameGarage";

	<div class="max-w-6xl mx-auto px-4 py-8 mt-20">

		@* {{-- Page title --}} *@
		<div class="flex flex-col lg:flex-row gap-6">

			@* {{-- ── LEFT COLUMN ───────────────────── --}} *@
			<div class="lg:w-2/3 flex flex-col gap-3">

				@if (Model.Screenshots != null)
				{
					@* {{-- Main display --}} *@
					<div class="relative overflow-hidden"
						 style="height:400px; border-radius:14px; border:1px solid #153352; background:#040c14;">
						<img id="mainDisplay"
							 src="@Model.HeaderImage"
							 class="w-full h-full object-cover" />
						@* {{-- bottom fade --}} *@
						<div class="absolute bottom-0 left-0 right-0 h-16 pointer-events-none"
							 style="background:linear-gradient(to top,rgba(2,5,9,0.7),transparent)"></div>
					</div>

					@* {{-- Thumbnail strip --}} *@
					<div class="w-full overflow-x-auto pb-1 scrollbar-thin scrollbar-thumb-gray-600 scrollbar-track-transparent">
						<div class="flex gap-2 w-max">

							<img src="@Model.HeaderImage"
								 onclick="swapImage('@Model.HeaderImage')"
								 class="thumb-img w-24 h-16 object-cover cursor-pointer shrink-0"
								 style="border-radius:8px; border:2px solid #eb5e28;" />

							@foreach (string s in Model.Screenshots)
							{
								<img src="@s"
									 onclick="swapImage('@s')"
									 class="thumb-img w-24 h-16 object-cover cursor-pointer shrink-0"
									 style="border-radius:8px; border:2px solid #1c4268; transition:border-color .15s;" />
							}

						</div>
					</div>
				}
				else
				{
					<div class="flex items-center justify-center"
						 style="height:400px; border-radius:14px; border:1px solid #153352; background:#040c14;">
						<img id="mainDisplay" alt="Main" class="w-full h-full object-cover" style="border-radius:14px;" />
					</div>
					<div class="flex gap-2">
						<img src="#" onclick="swapImage('image1.jpg')" alt="No image"
							 class="w-20 h-12 cursor-pointer"
							 style="border-radius:8px; border:2px solid #eb5e28;" />
					</div>
				}

				@* {{-- About section --}} *@
				<div class="mt-2 p-6"
					 style="border-radius:14px; background:#0b1929; border:1px solid #153352;">
					<h1 class="text-3xl font-bold text-white mb-6 tracking-tight"
						style="font-family:'Syne',sans-serif; letter-spacing:-.02em;">
						@Model.Name
					</h1>

					<h2 class="text-white text-lg font-bold mb-4"
						style="font-family:'Syne',sans-serif; letter-spacing:.02em;">
						About the Game
					</h2>
					<p class="text-sm leading-relaxed" style="color:#8ab4d4;">
						@Model.AboutTheGame
					</p>
				</div>

			</div>

			@* {{-- ── RIGHT COLUMN ──────────────────── --}} *@
			<div class="lg:w-1/3 flex flex-col gap-4">

				@* {{-- Purchase card --}} *@
				<div style="border-radius:16px; background:#0b1929; border:1px solid #153352; overflow:hidden;">

					<img src="@Model.HeaderImage" alt="@Model.Name"
						 class="w-full object-cover"
						 style="height:180px; display:block;" />

					<div class="p-5 flex flex-col gap-4">

						@if (Model.AboutTheGame != null && Model.AboutTheGame.Length > 300)
						{
							<p class="text-xs leading-relaxed" style="color:#5e809e;">
								@Model.AboutTheGame.Substring(0, 300)…
							</p>
						}

						@* {{-- Price --}} *@
						<div class="flex items-baseline gap-2">
                            @if (Model.Price != 0)
                            {
                                <span class="text-2xl font-bold text-white"
                                      style="font-family:'Syne',sans-serif;">
                                      $@Model.Price
                                </span>
                                <div class="list-item-badge lb-paid">Released</div>
                            }
                            else
                            {
                                <span class="text-2xl font-bold text-white free"
                                      style="font-family:'Syne',sans-serif;">
                                      Free
                                </span>
                                <div class="list-item-badge lb-free">F2P</div>
                            }
						</div>

						@* {{-- Buttons --}} *@
						<button class="w-full py-2.5 text-sm font-bold text-white transition-all"
								style="background:#eb5e28; border-radius:10px; font-family:'Syne',sans-serif;
		                                       letter-spacing:.04em; box-shadow:0 4px 18px rgba(235,94,40,0.35);">
							Buy Now
						</button>

						<button class="w-full py-2.5 text-sm font-semibold transition-all"
								style="background:#0e2035; border:1px solid #1c4268; border-radius:10px;
		                                       color:#8ab4d4; letter-spacing:.02em;">
							Add to Cart
						</button>

						<button class="w-full py-2 text-xs transition-all flex items-center justify-center gap-2"
								style="background:transparent; border:1px solid #153352; border-radius:8px; color:#3d6a8a;">
							<svg style="width:13px;height:13px;stroke:currentColor;fill:none" viewBox="0 0 24 24">
								<path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" />
							</svg>
							Add to Wishlist
						</button>

					</div>
				</div>

				@* {{-- Metadata --}} *@
				<div class="p-5"
					 style="border-radius:14px; background:#0b1929; border:1px solid #153352;">

					<div class="grid gap-y-3 text-xs" style="grid-template-columns:130px 1fr;">

						<div style="color:#3d6a8a; text-transform:uppercase; letter-spacing:.1em; font-weight:700;">
							Release Date
						</div>
						<div style="color:#8ab4d4;">@Model.ReleaseDate</div>

						<div style="color:#3d6a8a; text-transform:uppercase; letter-spacing:.1em; font-weight:700;">
							Developer
						</div>
						<div class="cursor-pointer hover:underline" style="color:#eb5e28;">
							@Model.Developers
						</div>

						<div style="color:#3d6a8a; text-transform:uppercase; letter-spacing:.1em; font-weight:700;">
							Publisher
						</div>
						<div class="cursor-pointer hover:underline" style="color:#eb5e28;">
							@Model.Publishers
						</div>

					</div>
				</div>

				@* {{-- Tags --}} *@
				<div class="p-5"
					 style="border-radius:14px; background:#0b1929; border:1px solid #153352;">

					<div class="text-xs font-bold uppercase tracking-widest mb-3" style="color:#3d6a8a;">
						Tags
					</div>

					<div class="flex flex-wrap gap-1.5">
						@foreach (string tag in (Model.Tags.Split(',')) ?? Enumerable.Empty<string>())
						{
							<span class="text-xs px-2.5 py-1 cursor-pointer transition-all"
								  style="background:rgba(235,94,40,0.08); color:#eb5e28;
				                                         border:1px solid rgba(235,94,40,0.18); border-radius:6px;">
								@tag
							</span>
						}
						<span class="text-xs font-bold px-2.5 py-1 cursor-pointer transition-all"
							  style="background:#0e2035; color:#3d6a8a;
		                                     border:1px solid #153352; border-radius:6px;">
							+
						</span>
					</div>
				</div>

			</div>
		</div>
	</div>

	<script>
		function swapImage(newSrc) {
			// 1. Swap main image
			const mainImg = document.getElementById('mainDisplay');
			mainImg.src = newSrc;

			// 2. Update active thumbnail border
			document.querySelectorAll('.thumb-img').forEach(thumb => {
				const match = thumb.src === newSrc || thumb.src.endsWith(newSrc);
				thumb.style.borderColor = match ? '#eb5e28' : '#1c4268';
			});
		}
	</script>
}