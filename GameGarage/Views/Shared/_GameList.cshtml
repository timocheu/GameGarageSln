@model IEnumerable<Game>
@{
	var title = ViewData["Section"] as string;

	int count = 1;
}
<div class="list-col">
	<div class="list-col-header">
		<div class="list-col-title">
			@title
		</div>
	</div>

	<ul class="space-y-4">
		@foreach (var game in @Model.ToList() ?? Enumerable.Empty<Game>())
		{
			<a class="block" asp-controller="Games" asp-action="Details" asp-route-id="@game.Id">
			<li class="relative group flex items-center bg-[#0a0a0a] border border-transparent hover:border-gray-700 transition-all rounded-sm overflow-hidden h-32">

				<div class="absolute left-4 top-1/2 -translate-y-1/2 text-5xl font-black text-gray-800/50 italic z-10 select-none">
					@(count++)
				</div>

				<div class="absolute right-0 top-0 w-2/3 h-full">
					<img src="@game.HeaderImage" alt="Header" class="w-full h-full object-cover opacity-40 group-hover:opacity-60 transition-opacity">
					<div class="absolute inset-0 bg-gradient-to-r from-[#0a0a0a] via-[#0a0a0a]/80 to-transparent"></div>
				</div>

				<div class="relative z-20 flex w-full items-center justify-between px-16">
					<div class="flex items-center gap-6">
						<div>
							<h3 class="text-xl font-bold uppercase tracking-tight group-hover:text-orange-500 transition-colors">@game.Name</h3>
							<div class="flex gap-2 mt-1">
								@foreach (string tag in (game.Tags ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries).Take(3))
								{
									<span class="text-[10px] text-gray-500 border border-gray-800 px-1 uppercase tracking-tighter">@tag.Trim()</span>
								}
							</div>
						</div>
					</div>

					<div class="text-right">
						@if (game.Price != 0)
						{
							<div class="text-xl font-mono font-bold">$@game.Price.ToString("F2")</div>
							<span class="inline-block mt-1 bg-orange-600/10 text-orange-500 text-[10px] font-black px-2 py-0.5 rounded border border-orange-600/20 uppercase tracking-widest">
								Released
							</span>
						}
						else
						{
							<div class="text-xl font-mono font-bold">Free</div>
							<span class="inline-block mt-1 bg-orange-600/10 text-green-500 text-[10px] font-black px-2 py-0.5 rounded border border-green-600/20 uppercase tracking-widest">
								F2P
							</span>
						}
					</div>
				</div>
			</li>
			</a>
		}
	</ul>

</div>


