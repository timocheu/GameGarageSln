<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Game Garage</title>
	<script src="https://cdn.tailwindcss.com"></script>
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
	<script>
		tailwind.config = {
		  theme: {
			extend: {
			  fontFamily: {
				sans: ['Inter', 'ui-sans-serif', 'system-ui'],
			  },
			}
		  }
		}
	</script>
</head>

<body class="font-sans antialiased">
	@* Navigation bar *@
	<nav class="flex items-center justify-between px-8 py-4 border-b border-gray-800">
		<div class="flex items-center space-x-8">
			<h1 class="text-2xl font-black tracking-tighter italic">GAME GARAGE</h1>
			<div class="relative">
				<input type="text" placeholder="Search"
					   class="bg-[#0a1628] border border-gray-700 rounded-sm px-10 py-1 text-sm w-80 focus:outline-none focus:border-blue-500">
				<svg class="w-4 h-4 absolute left-3 top-2 text-gray-400" fill="none" stroke="currentColor"
					 viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
						  d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
				</svg>
			</div>
		</div>
		<div class="flex items-center space-x-6 text-xs font-medium uppercase tracking-widest text-gray-300">
			<a href="#" class="hover:text-white">Download</a>
			<a href="#" class="hover:text-white">About</a>
			<a href="#" class="hover:text-white">Account</a>
		</div>
	</nav>

	<div>
		@RenderBody()
	</div>


	<footer class="mt-20 border-t border-gray-900 bg-black/30 py-12 px-8">
		<div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start">
			<div class="mb-8 md:mb-0">
				<h2 class="text-xl font-black italic mb-4">GameGarage</h2>
				<div class="text-xs text-gray-500 space-y-2">
					<p>Contact us</p>
					<p>(+63) 900 000 000</p>
					<p>hello@gamegarage.com</p>
				</div>
			</div>
			<div class="grid grid-cols-2 gap-12 text-xs">
				<div>
					<h4 class="font-bold text-gray-300 mb-4 uppercase">Company</h4>
					<ul class="space-y-2 text-gray-500">
						<li><a href="#">Terms & Conditions</a></li>
						<li><a href="#">Privacy Policy</a></li>
						<li><a href="#">Career</a></li>
					</ul>
				</div>
				<div>
					<h4 class="font-bold text-gray-300 mb-4 uppercase">Download</h4>
					<ul class="space-y-2 text-gray-500">
						<li><a href="#">Windows</a></li>
						<li><a href="#">Linux</a></li>
						<li><a href="#">MacOS</a></li>
					</ul>
				</div>
			</div>
		</div>
		<div class="text-center text-[10px] text-gray-700 mt-12 border-t border-gray-900 pt-8">
			© 2026 GameGarage All Rights Reserved.
		</div>
	</footer>

</body>
</html>
