@model CatalogListViewModel
@{
    ViewBag.Title = "Game Garage";
}

<div class="max-w-5xl mx-auto p-6 space-y-4 bg-black min-h-screen text-gray-300 m-20">

    <div class="flex-row justify-between items-center mb-8 border-b border-gray-800 pb-4">
        <div>
            <h2 class="text-2xl font-bold text-white uppercase tracking-wider">Current Page: <span class="text-orange-500">@Model.PagingInfo.CurrentPage</span></h2>
        </div>
        <div class="pagination-container">
              <a href="#">&lt;</a>

              <div class="pagination-group" page-model="@Model.PagingInfo" page-action="@Model.PagingInfo.Action">
              </div>

              <a href="#">&gt;</a>
            </div>
    </div>

    @foreach (Game game in Model.Games ?? Enumerable.Empty<Game>())
    {
        <div class="group flex flex-col md:flex-row bg-[#0a0a0a] border border-gray-800 rounded-lg overflow-hidden hover:border-orange-500/50 transition-all duration-300 shadow-2xl">

            <div class="relative w-full md:w-80 h-48 md:h-auto shrink-0">
                <img src="@game.HeaderImage" alt="Game Title" class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity" />
            </div>

            <div class="flex-1 p-6 flex flex-col justify-between">
                <div>
                    <div class="flex justify-between items-start">
                        <div>
                            <h3 class="text-3xl font-black text-white uppercase leading-none tracking-tight">
                                GAME <span class="text-orange-500 block">@game.Name</span>
                            </h3>
                            <p class="text-xs text-gray-500 mt-2 font-mono uppercase">Dev: <span class="text-gray-300 italic">@game.Developers</span></p>
                        </div>
                        <div class="text-right">
                            @if (game.Price != 0)
                            {
                                <span class="text-2xl font-bold text-orange-500">$@game.Price.ToString("F2")</span>
                            }
                            else
                            {
                                <span class="text-2xl font-bold text-green-500">Free</span>

                            }
                            <div class="text-[10px] text-gray-500 uppercase mt-1">Released: @game.ReleaseDate.ToString("d")</div>
                        </div>
                    </div>

                    <p class="mt-4 text-sm text-gray-400 line-clamp-2 leading-relaxed max-w-xl">
                        @if (game.AboutTheGame != null && game.AboutTheGame.Length > 30)
                        {
                            @game.AboutTheGame.Substring(30)
                        }
                        else
                        {
                            @game.AboutTheGame
                        }
                    </p>

                    <div class="flex flex-wrap gap-2 mt-4">
                        @foreach (string tag in (game.Tags.Split(',')!).Take(3))
                        {
                            <span class="px-2 py-1 bg-gray-900 border border-gray-700 text-[10px] text-gray-400 rounded uppercase tracking-widest group-hover:border-gray-600">
                                @tag
                            </span>
                        }
                        <span class="px-2 py-1 bg-gray-900 border border-gray-700 text-[10px] text-gray-400 rounded uppercase tracking-widest group-hover:border-gray-600">
                            +
                        </span>
                    </div>
                </div>

                <div class="flex items-center justify-between mt-6 pt-4 border-t border-gray-900/50">
                    <div class="flex gap-4 text-xs text-gray-500">
                        @if (game.Windows != "")
                        {
                            <i class="fab fa-windows" title="Windows"></i>
                        }
                        @if (game.Mac != "")
                        {
                            <i class="fab fa-apple" title="Mac"></i>
                        }
                        @if (game.Linux != "")
                        {
                            <i class="fab fa-apple" title="Linux"></i>
                        }
                    </div>

                    <div class="flex gap-3">
                        <button class="px-4 py-2 border border-gray-700 text-xs font-bold uppercase tracking-widest text-gray-300 hover:bg-gray-800 rounded transition-colors">
                            Add to Wishlist
                        </button>
                        <a asp-controller="Game"
                           asp-action="Details"
                           asp-route-id="@game.Id"
                           class="px-6 py-2 bg-orange-600 text-white text-[10px] font-black uppercase tracking-widest rounded hover:bg-orange-500 shadow-[0_0_15px_rgba(234,88,12,0.3)] transition-all inline-block">
                            Play Now
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
