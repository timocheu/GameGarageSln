@model GameGarage.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
    Layout = "_Layout";
}

<div class="min-h-screen bg-[#0b0e14] flex flex-col justify-center py-12 sm:px-6 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-md">
        <div class="flex justify-center">
            <div class="h-16 w-16 bg-orange-600 rounded-2xl flex items-center justify-center shadow-lg shadow-orange-600/20">
                <i class="fas fa-user-plus text-white text-2xl"></i>
            </div>
        </div>
        <h2 class="mt-6 text-center text-3xl font-extrabold text-white tracking-tight">
            Join Game Garage
        </h2>
        <p class="mt-2 text-center text-sm text-gray-400">
            Create an account to manage your inventory
        </p>
    </div>

    <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
        <div class="bg-[#12161f] py-8 px-4 shadow-2xl border border-gray-800 sm:rounded-3xl sm:px-10">
            <form asp-action="Register" method="post" class="space-y-6">
                <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm list-none bg-red-500/10 p-4 rounded-xl border border-red-500/20"></div>
                
                <div>
                    <label asp-for="Email" class="block text-sm font-medium text-gray-400">
                        Email Address
                    </label>
                    <div class="mt-1 relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <i class="fas fa-envelope text-gray-500"></i>
                        </div>
                        <input asp-for="Email" 
                               class="block w-full bg-[#1a1f29] border border-gray-800 text-gray-200 text-sm rounded-xl py-3 pl-11 focus:outline-none focus:ring-2 focus:ring-orange-600/50 focus:border-orange-600 transition-all placeholder:text-gray-600"
                               placeholder="name@example.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-red-500 text-xs mt-1"></span>
                </div>

                <div>
                    <label asp-for="Password" class="block text-sm font-medium text-gray-400">
                        Password
                    </label>
                    <div class="mt-1 relative group">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <i class="fas fa-lock text-gray-500"></i>
                        </div>
                        <input asp-for="Password" 
                               id="passwordInput"
                               class="block w-full bg-[#1a1f29] border border-gray-800 text-gray-200 text-sm rounded-xl py-3 pl-11 pr-11 focus:outline-none focus:ring-2 focus:ring-orange-600/50 focus:border-orange-600 transition-all placeholder:text-gray-600" />
                        <button type="button" 
                                onclick="togglePassword('passwordInput', 'passwordIcon')"
                                class="absolute inset-y-0 right-0 pr-4 flex items-center text-gray-500 hover:text-orange-500 transition-colors">
                            <i id="passwordIcon" class="fas fa-eye-slash"></i>
                        </button>
                    </div>
                    
                    <!-- Password Strength Indicator -->
                    <div class="mt-3 space-y-2">
                        <div class="flex justify-between items-center px-1">
                            <span id="strengthLabel" class="text-[10px] font-bold uppercase tracking-wider text-gray-600">Password Strength</span>
                            <span id="strengthText" class="text-[10px] font-bold uppercase tracking-wider text-gray-600">—</span>
                        </div>
                        <div class="h-1.5 w-full bg-gray-800 rounded-full overflow-hidden flex gap-1 p-0.5">
                            <div id="bar-1" class="h-full w-1/4 rounded-full bg-gray-700 transition-all duration-500"></div>
                            <div id="bar-2" class="h-full w-1/4 rounded-full bg-gray-700 transition-all duration-500"></div>
                            <div id="bar-3" class="h-full w-1/4 rounded-full bg-gray-700 transition-all duration-500"></div>
                            <div id="bar-4" class="h-full w-1/4 rounded-full bg-gray-700 transition-all duration-500"></div>
                        </div>
                        <ul id="strengthRequirements" class="grid grid-cols-2 gap-x-4 gap-y-1 px-1">
                            <li id="req-length" class="text-[10px] text-gray-600 flex items-center gap-1.5 transition-colors">
                                <i class="fas fa-circle text-[4px]"></i> 8+ Characters
                            </li>
                            <li id="req-upper" class="text-[10px] text-gray-600 flex items-center gap-1.5 transition-colors">
                                <i class="fas fa-circle text-[4px]"></i> Uppercase
                            </li>
                            <li id="req-number" class="text-[10px] text-gray-600 flex items-center gap-1.5 transition-colors">
                                <i class="fas fa-circle text-[4px]"></i> Number
                            </li>
                            <li id="req-symbol" class="text-[10px] text-gray-600 flex items-center gap-1.5 transition-colors">
                                <i class="fas fa-circle text-[4px]"></i> Symbol
                            </li>
                        </ul>
                    </div>

                    <span asp-validation-for="Password" class="text-red-500 text-xs mt-1"></span>
                </div>

                <div>
                    <label asp-for="ConfirmPassword" class="block text-sm font-medium text-gray-400">
                        Confirm Password
                    </label>
                    <div class="mt-1 relative group">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <i class="fas fa-shield-alt text-gray-500"></i>
                        </div>
                        <input asp-for="ConfirmPassword" 
                               id="confirmPasswordInput"
                               class="block w-full bg-[#1a1f29] border border-gray-800 text-gray-200 text-sm rounded-xl py-3 pl-11 pr-11 focus:outline-none focus:ring-2 focus:ring-orange-600/50 focus:border-orange-600 transition-all placeholder:text-gray-600" />
                        <button type="button" 
                                onclick="togglePassword('confirmPasswordInput', 'confirmPasswordIcon')"
                                class="absolute inset-y-0 right-0 pr-4 flex items-center text-gray-500 hover:text-orange-500 transition-colors">
                            <i id="confirmPasswordIcon" class="fas fa-eye-slash"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-red-500 text-xs mt-1"></span>
                </div>

                <div>
                    <button type="submit" 
                            class="w-full flex justify-center py-3 px-4 border border-transparent rounded-xl shadow-lg text-sm font-bold text-white bg-orange-600 hover:bg-orange-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-600 transition-all shadow-orange-600/20">
                        Register Account
                    </button>
                </div>
            </form>

            <div class="mt-6 text-center">
                <p class="text-sm text-gray-400">
                    Already have an account? 
                    <a asp-action="Login" class="font-medium text-orange-500 hover:text-orange-400">
                        Sign in
                    </a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            } else {
                input.type = 'password';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            }
        }

        document.getElementById('passwordInput').addEventListener('input', function (e) {
            const password = e.target.value;
            const bars = [
                document.getElementById('bar-1'),
                document.getElementById('bar-2'),
                document.getElementById('bar-3'),
                document.getElementById('bar-4')
            ];
            const text = document.getElementById('strengthText');
            const reqs = {
                length: document.getElementById('req-length'),
                upper: document.getElementById('req-upper'),
                number: document.getElementById('req-number'),
                symbol: document.getElementById('req-symbol')
            };

            // Criteria
            const hasLength = password.length >= 8;
            const hasUpper = /[A-Z]/.test(password);
            const hasNumber = /[0-9]/.test(password);
            const hasSymbol = /[!@@#$%^&*(),.?":{}|<>]/.test(password);

            // Update individual requirement colors
            const updateReq = (el, met) => {
                if (met) {
                    el.classList.remove('text-gray-600');
                    el.classList.add('text-green-500');
                } else {
                    el.classList.add('text-gray-600');
                    el.classList.remove('text-green-500');
                }
            };

            updateReq(reqs.length, hasLength);
            updateReq(reqs.upper, hasUpper);
            updateReq(reqs.number, hasNumber);
            updateReq(reqs.symbol, hasSymbol);

            // Strength score
            let score = 0;
            if (password.length > 0) {
                if (hasLength) score++;
                if (hasUpper) score++;
                if (hasNumber) score++;
                if (hasSymbol) score++;
                
                // Extra weight for length
                if (password.length >= 12) score = Math.max(score, 3);
            }

            // Reset bars
            bars.forEach(bar => {
                bar.className = 'h-full w-1/4 rounded-full bg-gray-700 transition-all duration-500';
            });

            const colors = ['bg-red-500', 'bg-orange-500', 'bg-yellow-500', 'bg-green-500'];
            const labels = ['Weak', 'Fair', 'Good', 'Strong'];

            if (password.length > 0) {
                const strengthIndex = Math.max(0, score - 1);
                text.innerText = labels[strengthIndex];
                text.className = `text-[10px] font-bold uppercase tracking-wider ${colors[strengthIndex].replace('bg-', 'text-')}`;
                
                for (let i = 0; i <= strengthIndex; i++) {
                    bars[i].classList.remove('bg-gray-700');
                    bars[i].classList.add(colors[strengthIndex]);
                }
            } else {
                text.innerText = '—';
                text.className = 'text-[10px] font-bold uppercase tracking-wider text-gray-600';
            }
        });
    </script>
}
