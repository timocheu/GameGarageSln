@model GameGarage.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "_Layout";
}

<div class="min-h-screen bg-[#0b0e14] flex flex-col justify-center py-12 sm:px-6 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-md">
        <div class="flex justify-center">
            <div class="h-16 w-16 bg-orange-600 rounded-2xl flex items-center justify-center shadow-lg shadow-orange-600/20">
                <i class="fas fa-lock text-white text-2xl"></i>
            </div>
        </div>
        <h2 class="mt-6 text-center text-3xl font-extrabold text-white tracking-tight">
            Sign In to Game Garage
        </h2>
        <p class="mt-2 text-center text-sm text-gray-400">
            Welcome back to your dashboard
        </p>
    </div>

    <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
        <div class="bg-[#12161f] py-8 px-4 shadow-2xl border border-gray-800 sm:rounded-3xl sm:px-10">
            <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="space-y-6">
                <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm list-none bg-red-500/10 p-4 rounded-xl border border-red-500/20"></div>
                
                <div>
                    <label asp-for="Email" class="block text-sm font-medium text-gray-400">
                        Email Address
                    </label>
                    <div class="mt-1 relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <i class="fas fa-envelope text-gray-500"></i>
                        </div>
                        <input asp-for="Email" 
                               class="block w-full bg-[#1a1f29] border border-gray-800 text-gray-200 text-sm rounded-xl py-3 pl-11 focus:outline-none focus:ring-2 focus:ring-orange-600/50 focus:border-orange-600 transition-all placeholder:text-gray-600"
                               placeholder="name@example.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-red-500 text-xs mt-1"></span>
                </div>

                <div>
                    <label asp-for="Password" class="block text-sm font-medium text-gray-400">
                        Password
                    </label>
                    <div class="mt-1 relative group">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <i class="fas fa-key text-gray-500"></i>
                        </div>
                        <input asp-for="Password" 
                               id="passwordInput"
                               class="block w-full bg-[#1a1f29] border border-gray-800 text-gray-200 text-sm rounded-xl py-3 pl-11 pr-11 focus:outline-none focus:ring-2 focus:ring-orange-600/50 focus:border-orange-600 transition-all placeholder:text-gray-600" />
                        <button type="button" 
                                onclick="togglePassword('passwordInput', 'passwordIcon')"
                                class="absolute inset-y-0 right-0 pr-4 flex items-center text-gray-500 hover:text-orange-500 transition-colors">
                            <i id="passwordIcon" class="fas fa-eye-slash"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-red-500 text-xs mt-1"></span>
                </div>

                <div class="flex items-center justify-between">
                    <div class="flex items-center">
                        <input asp-for="RememberMe" 
                               class="h-4 w-4 bg-[#1a1f29] border-gray-800 text-orange-600 focus:ring-orange-500 rounded-sm">
                        <label asp-for="RememberMe" class="ml-2 block text-sm text-gray-400">
                            Remember me
                        </label>
                    </div>
                </div>

                <div>
                    <button type="submit" 
                            class="w-full flex justify-center py-3 px-4 border border-transparent rounded-xl shadow-lg text-sm font-bold text-white bg-orange-600 hover:bg-orange-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-600 transition-all shadow-orange-600/20">
                        Sign In
                    </button>
                </div>
            </form>

            <div class="mt-6 text-center">
                <p class="text-sm text-gray-400">
                    Don't have an account? 
                    <a asp-action="Register" class="font-medium text-orange-500 hover:text-orange-400">
                        Register now
                    </a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            } else {
                input.type = 'password';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            }
        }
    </script>
}
