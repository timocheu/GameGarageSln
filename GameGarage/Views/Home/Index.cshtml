@model HomeViewModel
@{
    ViewBag.Title = "Game Garage";
}

<!-- HERO  -->
<section class="hero">
    <div class="hero-slide active slide-1" id="slide-1"></div>
    <div class="hero-slide inactive slide-2" id="slide-2"></div>
    <div class="hero-slide inactive slide-3" id="slide-3"></div>
    <div class="hero-bg"></div>

    <div class="hero-content">
        <div class="hero-tag fade-in"><span></span> Featured Release</div>
        <h1 class="hero-title fade-in delay-1">BLACK MYTH<br><em>WUKONG</em></h1>
        <p class="hero-desc fade-in delay-2">Journey as the Destined One through a breathtaking world rooted in Chinese mythology. Face legendary beings and uncover a long-forgotten truth.</p>
        <div class="hero-actions fade-in delay-3">
            <button class="btn-hero-primary">
                <svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3" fill="#fff" stroke="none" /></svg>
                Play Now � $49.99
            </button>
            <button class="btn-hero-ghost">Add to Wishlist</button>
        </div>
        <div class="hero-meta fade-in delay-4">
            <div class="hero-meta-item">
                <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" fill="rgba(235,94,40,0.3)" stroke="#eb5e28" stroke-width="1.5" /></svg>
                <strong>9.4</strong> Metacritic
            </div>
            <div class="hero-meta-sep"></div>
            <div class="hero-meta-item">
                <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" /></svg>
                <strong>2.4M</strong> Players
            </div>
            <div class="hero-meta-sep"></div>
            <div class="hero-meta-item">
                <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2" /><line x1="8" y1="21" x2="16" y2="21" /></svg>
                <strong>PC</strong> &amp; Console
            </div>
        </div>
    </div>

    <!-- Slide thumbnails -->
    <div class="hero-slides-nav">
        <div class="slide-thumb active" onclick="goSlide(0)">
            <div class="slide-thumb-inner slide-t1">Wukong</div>
        </div>
        <div class="slide-thumb" onclick="goSlide(1)">
            <div class="slide-thumb-inner slide-t2">GTA</div>
        </div>
        <div class="slide-thumb" onclick="goSlide(2)">
            <div class="slide-thumb-inner slide-t3">Stardew</div>
        </div>
    </div>

    <div class="scroll-hint">
        <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9" /></svg>
        Scroll
    </div>
</section>

<!--  FEATURED GAMES  -->
<partial name="_FeaturedGames" model="Model.Features" />

<!-- ??? NEW RELEASES + TOP RATED + MOST PLAYED ?? -->
<section class="lists-section">
    <div class="lists-grid">

        <partial name="_GameList" model="Model.NewRelease" view-data='new ViewDataDictionary(ViewData) { { "Section", "New Releases" } }' />
        <partial name="_GameList" model="Model.TopPlayerRated" view-data='new ViewDataDictionary(ViewData) { { "Section", "Top Player Rated" } }' />
        <partial name="_GameList" model="Model.MostPlayed" view-data='new ViewDataDictionary(ViewData) { { "Section", "Most Played" } }' />


    </div>
</section>

<!-- ??? PROMO BANNER ??????????????????????? -->
<div class="promo-banner">
    <div class="promo-text">
        <div class="promo-eyebrow">Spring Sale � Ends March 20</div>
        <div class="promo-title">UP TO <em>70% OFF</em><br>EPIC TITLES</div>
        <p class="promo-desc">Over 400 games deeply discounted. Don't miss out � the biggest sale of the season is live now.</p>
        <div class="promo-actions">
            <button class="btn-hero-primary" style="font-size:12.5px;padding:11px 22px">
                <svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3" fill="#fff" stroke="none" /></svg>
                Browse Sale
            </button>
            <button class="btn-hero-ghost" style="font-size:12.5px;padding:11px 20px">Set Reminder</button>
        </div>
    </div>
</div>


<script>
    // Hero slideshow
    const slides = ['slide-1','slide-2','slide-3'];
    const thumbs = document.querySelectorAll('.slide-thumb');
    const heroTitles = [
      { tag:'Featured Release', title:'BLACK MYTH\n<em>WUKONG</em>', desc:'Journey as the Destined One through a breathtaking world rooted in Chinese mythology.', price:'$49.99', image: 'https://preview.redd.it/black-myth-wukong-8k-resolution-wallpaper-v0-kyuamtohf8gd1.jpg?width=3840&format=pjpg&auto=webp&s=77ea2ce3c89e94f49ab717e763f378137bec7dd7'},
      { tag:'Most Popular', title:'GRAND THEFT\n<em>ONLINE</em>', desc:'The ever-evolving online world of Los Santos. Hundreds of missions, heists, and more.', price:'Free', image: 'https://4kwallpapers.com/images/wallpapers/grand-theft-auto-v-2560x1440-10734.jpg' },
      { tag:'Fan Favourite', title:'READY OR\n<em>NOT</em>', desc:'Make a crazy comeback. Through team operation undermining the enemy.', price:'$49.99', image: 'https://4kwallpapers.com/images/wallpapers/swat-ready-or-not-3840x2160-23256.jpg' }
    ];
    let current = 0;

    function goSlide(idx) {
      document.getElementById(slides[current]).className = 'hero-slide inactive ' + 'slide-' + (current+1);
      thumbs[current].classList.remove('active');
      current = idx;
      document.getElementById(slides[current]).className = 'hero-slide active ' + 'slide-' + (current+1);
      thumbs[current].classList.add('active');
      const t = heroTitles[current];
      document.querySelector('.hero-tag').innerHTML = '<span></span> ' + t.tag;
      document.querySelector('.hero-title').innerHTML = t.title.replace('\n','<br>');
      document.querySelector('.hero-desc').textContent = t.desc;
      const hero = document.querySelector('.hero-bg');

      hero.style.backgroundImage = `url('${t.image}')`;
      hero.style.backgroundSize = "cover"; // Ensures it fits nicely
      document.querySelector('.btn-hero-primary').innerHTML = `<svg viewBox="0 0 24 24" style="width:16px;height:16px;stroke:#fff;fill:#fff"><polygon points="5 3 19 12 5 21 5 3" fill="#fff" stroke="none"/></svg> Play Now � ${t.price}`;
    }

    setInterval(() => goSlide((current + 1) % slides.length), 5000);

    // Genre tab switching
    document.querySelectorAll('.genre-tab').forEach(t => {
      t.addEventListener('click', () => {
        document.querySelectorAll('.genre-tab').forEach(x => x.classList.remove('active'));
        t.classList.add('active');
      });
    });
</script>
