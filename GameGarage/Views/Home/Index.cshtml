@model HomeViewModel

<section class="max-w-7xl mx-auto mt-8 px-4 relative group" id="hero-carousel">
	<div class="relative h-[450px] overflow-hidden rounded-lg bg-gray-900 shadow-2xl border border-gray-800">

		@foreach (var slide in Model.Slides ?? Enumerable.Empty<Game>())
		{
			<div class="carousel-slide absolute inset-0 transition-opacity duration-700 opacity-0 pointer-events-none" data-index="@slide.Id">
				<div class="relative w-full h-full">
					<img src="@slide.HeaderImage"
						 alt="@slide.Name"
						 class="w-full h-full object-cover object-center shadow-inner" />

					<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent"></div>

					<div class="absolute bottom-16 left-12">
						<h2 class="text-3xl font-bold text-white uppercase italic tracking-tighter">@slide.Name</h2>
					</div>
				</div>
			</div>
		}

		<button onclick="moveSlide(-1)" class="absolute left-4 top-1/2 -translate-y-1/2 bg-black/50 hover:bg-blue-600 text-white p-3 rounded-full opacity-0 group-hover:opacity-100 transition-all z-10">
			<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
		</button>
		<button onclick="moveSlide(1)" class="absolute right-4 top-1/2 -translate-y-1/2 bg-black/50 hover:bg-blue-600 text-white p-3 rounded-full opacity-0 group-hover:opacity-100 transition-all z-10">
			<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
		</button>

		<div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex space-x-3 z-10">
			@foreach (var slide in Model.Slides ?? Enumerable.Empty<Game>())
			{
				<button onclick="setSlide(@slide.Id)" class="carousel-dot h-1 transition-all duration-300 bg-gray-500 w-4 hover:bg-white" data-index="@slide.Id"></button>
			}
		</div>
	</div>
</section>

<main class="max-w-7xl mx-auto px-4 py-12">
	<h2 class="text-2xl font-bold mb-8 tracking-wide">FEATURED GAMES</h2>

	<div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-16">
		@foreach (var game in @Model.Features ?? Enumerable.Empty<Game>())
		{
			<div class="group cursor-pointer">
				<div class="aspect-[3/4] bg-[#0a1628] rounded mb-3 overflow-hidden border border-gray-800 group-hover:border-blue-500 transition-all duration-300 flex items-center justify-center">
						<img src="@game.HeaderImage"
							 alt="@game.Name"
							 class="w-full h-full object-cover object-center shadow-inner" />
				</div>
				<h3 class="font-bold text-sm leading-tight group-hover:text-blue-400">@game.Name</h3>
				<p class="text-[11px] text-gray-500 mt-1 italic">Tags</p>
			</div>
		}
	</div>

	<div class="grid grid-cols-1 md:grid-cols-3 gap-12">

		<div class="space-y-4">
			<h3 class="text-sm font-bold text-gray-400 mb-6 uppercase tracking-widest">New Releases</h3>
			@foreach (var game in @Model.NewRelease ?? Enumerable.Empty<Game>())
			{
				<div class="flex items-center space-x-4 p-2 hover:bg-white/5 rounded transition cursor-pointer">
					<div class="w-12 h-16 bg-gray-800 rounded flex-shrink-0 flex items-center justify-center border border-gray-700">
						<img src="@game.HeaderImage"
							 alt="@game.Name"
							 class="w-full h-full object-cover object-center shadow-inner" />
					</div>
					<div>
						<h4 class="text-sm font-bold">@game.Name</h4>
						<span class="text-[10px] bg-blue-600 px-1.5 py-0.5 rounded font-bold">Tag</span>
						<p class="text-xs text-gray-500 mt-1">Desc</p>
					</div>
				</div>
			}
		</div>

		<div class="space-y-4">
			<h3 class="text-sm font-bold text-gray-400 mb-6 uppercase tracking-widest">Top Player Rated</h3>
			@foreach (var game in @Model.TopPlayerRated ?? Enumerable.Empty<Game>())
			{
				<div class="flex items-center space-x-4 p-2 hover:bg-white/5 rounded transition cursor-pointer">
					<div class="w-12 h-16 bg-gray-800 rounded flex-shrink-0 flex items-center justify-center border border-gray-700">
						<img src="@game.HeaderImage"
							 alt="@game.Name"
							 class="w-full h-full object-cover object-center shadow-inner" />
					</div>
					<div>
						<h4 class="text-sm font-bold">@game.Name</h4>
						<span class="text-[10px] bg-blue-600 px-1.5 py-0.5 rounded font-bold">Tag</span>
						<p class="text-xs text-gray-500 mt-1">Lorem Ipsum</p>
					</div>
				</div>
			}
		</div>

		<div class="space-y-4">
			<h3 class="text-sm font-bold text-gray-400 mb-6 uppercase tracking-widest">Most Played</h3>
			@foreach (var game in @Model.MostPlayed ?? Enumerable.Empty<Game>())
			{
				<div class="flex items-center space-x-4 p-2 hover:bg-white/5 rounded transition cursor-pointer">
					<div class="w-12 h-16 bg-gray-800 rounded flex-shrink-0 flex items-center justify-center border border-gray-700">
						<img src="@game.HeaderImage"
							 alt="@game.Name"
							 class="w-full h-full object-cover object-center shadow-inner" />
					</div>
					<div>
						<h4 class="text-sm font-bold">@game.Name</h4>
						<span class="text-[10px] bg-blue-600 px-1.5 py-0.5 rounded font-bold">Tag</span>
						<p class="text-xs text-gray-500 mt-1">Desc</p>
					</div>
				</div>
			}
		</div>
	</div>
</main>

<script>
	let currentIndex = 0;
	const slides = document.querySelectorAll('.carousel-slide');
	const dots = document.querySelectorAll('.carousel-dot');

	function updateCarousel() {
		slides.forEach((slide, i) => {
			if (i === currentIndex) {
				slide.classList.remove('opacity-0', 'pointer-events-none');
				slide.classList.add('opacity-100');
			} else {
				slide.classList.add('opacity-0', 'pointer-events-none');
				slide.classList.remove('opacity-100');
			}
		});

		dots.forEach((dot, i) => {
			if (i === currentIndex) {
				dot.classList.add('bg-white', 'w-8');
				dot.classList.remove('bg-gray-500', 'w-4');
			} else {
				dot.classList.remove('bg-white', 'w-8');
				dot.classList.add('bg-gray-500', 'w-4');
			}
		});
	}

	function moveSlide(direction) {
		currentIndex = (currentIndex + direction + slides.length) % slides.length;
		updateCarousel();
	}

	function setSlide(index) {
		currentIndex = index;
		updateCarousel();
	}

	// Initialize
	updateCarousel();

	// Optional: Auto-slide every 5 seconds
	setInterval(() => moveSlide(1), 5000);
</script>