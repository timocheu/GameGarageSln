@model HomeViewModel
@{
    ViewBag.Title = "Game Garage";
}

<section class="max-w-7xl mx-auto mt-8 relative group overflow-hidden" id="hero-carousel">
    <div class="flex transition-transform duration-700 ease-out gap-6"
         id="carouselStage"
         style="transform: translateX(0px);">

        @foreach (var game in Model.Slides ?? Enumerable.Empty<Game>())
        {
            <div class="carousel-item relative shrink-0 w-[75%] md:w-[70%] h-[450px] rounded-lg overflow-hidden border border-gray-800 bg-gray-900 transition-all duration-500">
                <a asp-controller="Home" asp-action="App" asp-route-id="@game.Id">
                    <img src="@game.HeaderImage"
                         class="w-full h-full object-cover"
                         alt="@game.Name" />

                    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-transparent to-transparent"></div>
                    <div class="absolute bottom-10 left-10">
                        <h2 class="text-3xl font-bold uppercase italic tracking-tighter text-white">@game.Name</h2>
                    </div>
                </a>
            </div>
        }
    </div>

    <button onclick="moveStage(-1)" class="absolute left-6 top-1/2 -translate-y-1/2 bg-black/60 hover:bg-blue-600 text-white p-4 rounded-full z-30 opacity-0 group-hover:opacity-100 transition-opacity">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M15 19l-7-7 7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
    </button>
    <button onclick="moveStage(1)" class="absolute right-6 top-1/2 -translate-y-1/2 bg-black/60 hover:bg-blue-600 text-white p-4 rounded-full z-30 opacity-0 group-hover:opacity-100 transition-opacity">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
    </button>
</section>

<main class="max-w-7xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold mb-8 tracking-wide">FEATURED GAMES</h2>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-12 mb-16">
        @foreach (var game in @Model.Features ?? Enumerable.Empty<Game>())
        {
            <div class="group cursor-pointer">
                <a asp-controller="Home" asp-action="App" asp-route-id="@game.Id">
                    <div class="aspect-[3/4] bg-[#0a1628] rounded mb-3 overflow-hidden border border-gray-800 group-hover:border-blue-500 transition-all duration-300 flex items-center justify-center">

                        <img src="@game.HeaderImage"
                             alt="@game.Name"
                             class="w-sm h-full object-cover object-center shadow-inner" />

                    </div>
                    <h3 class="inter font-bold text-xl leading-tight group-hover:text-blue-400">@game.Name</h3>
                    <p class="text-[11px] text-gray-500 mt-1 italic text-sm">
                        @String.Join(", ", (game.Tags ?? Enumerable.Empty<string>()).Take(3))
                    </p>
                </a>
            </div>
        }
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

        <div class="space-y-4">
            <h3 class="text-sm font-bold text-gray-400 mb-6 uppercase tracking-widest">New Releases</h3>
            @foreach (var game in @Model.NewRelease ?? Enumerable.Empty<Game>())
            {
                <a asp-controller="Home" asp-action="App" asp-route-id="@game.Id">
                    <div class="flex items-center space-x-4 p-2 hover:bg-white/5 rounded transition cursor-pointer">
                        <div class="w-20 h-24 bg-gray-800 rounded flex-shrink-0 flex items-center justify-center border border-gray-700">
                            <img src="@game.HeaderImage"
                                 alt="@game.Name"
                                 class="w-full h-full object-cover object-center shadow-inner" />
                        </div>
                        <div>
                            <h4 class="text-lg font-bold">@game.Name</h4>
                            <span class="text-[10px] bg-blue-600 px-1.5 py-0.5 rounded font-bold">
                                @((game.Price == 0) ? "Free-2-Play" : game.Price.ToString("C"))
                            </span>
                            <p class="text-xs text-gray-500 mt-1">
                                @String.Join(", ", (game.Tags ?? Enumerable.Empty<string>()).Take(3))
                            </p>
                        </div>
                    </div>
                </a>
            }
        </div>

        <div class="space-y-4">
            <h3 class="text-sm font-bold text-gray-400 mb-6 uppercase tracking-widest">Top Player Rated</h3>
            @foreach (var game in @Model.TopPlayerRated ?? Enumerable.Empty<Game>())
            {
                <a asp-controller="Home" asp-action="App" asp-route-id="@game.Id">
                    <div class="flex items-center space-x-4 p-2 hover:bg-white/5 rounded transition cursor-pointer">
                        <div class="w-20 h-24 bg-gray-800 rounded flex-shrink-0 flex items-center justify-center border border-gray-700">
                            <img src="@game.HeaderImage"
                                 alt="@game.Name"
                                 class="w-full h-full object-cover object-center shadow-inner" />
                        </div>
                        <div>
                            <h4 class="text-lg font-bold">@game.Name</h4>
                            <span class="text-[10px] bg-blue-600 px-1.5 py-0.5 rounded font-bold">
                                @((game.Price == 0) ? "Free-2-Play" : game.Price.ToString("C"))
                            </span>
                            <p class="text-xs text-gray-500 mt-1">
                                @String.Join(", ", (game.Tags ?? Enumerable.Empty<string>()).Take(3))
                            </p>
                        </div>
                    </div>
                </a>
            }
        </div>

        <div class="space-y-4">
            <h3 class="text-sm font-bold text-gray-400 mb-6 uppercase tracking-widest">Most Played</h3>
            @foreach (var game in @Model.MostPlayed ?? Enumerable.Empty<Game>())
            {
                <a asp-controller="Home" asp-action="App" asp-route-id="@game.Id">
                    <div class="flex items-center space-x-4 p-2 hover:bg-white/5 rounded transition cursor-pointer">
                        <div class="w-20 h-24 bg-gray-800 rounded flex-shrink-0 flex items-center justify-center border border-gray-700">
                            <img src="@game.HeaderImage"
                                 alt="@game.Name"
                                 class="w-full h-full object-cover object-center shadow-inner" />
                        </div>
                        <div>
                            <h4 class="text-lg font-bold">@game.Name</h4>
                            <span class="text-[10px] bg-blue-600 px-1.5 py-0.5 rounded font-bold">
                                @((game.Price == 0) ? "Free-2-Play" : game.Price.ToString("C"))
                            </span>
                            <p class="text-xs text-gray-500 mt-1">
                                @String.Join(", ", (game.Tags ?? Enumerable.Empty<string>()).Take(3))
                            </p>
                        </div>
                    </div>
                </a>
            }
        </div>
    </div>
</main>

<script>
    let currentIndex = 0;
    const stage = document.getElementById('carouselStage');
    const items = document.querySelectorAll('.carousel-item');
    const container = document.getElementById('hero-carousel');

    function updateStage() {
        const containerWidth = container.offsetWidth;
        const itemWidth = items[0].offsetWidth;
        const gap = 24; // This must match your Tailwind 'gap-6' (6 * 4px)

        // Calculate how much to shift to put the currentIndex in the center
        // Formula: (ContainerWidth / 2) - (ItemWidth / 2) - (Total width of previous items + gaps)
        const centerOffset = (containerWidth / 2) - (itemWidth / 2);
        const scrollPosition = centerOffset - (currentIndex * (itemWidth + gap));

        stage.style.transform = `translateX(${scrollPosition}px)`;

        // Apply the "Dimming" effect to side images like the reference image
        items.forEach((item, i) => {
            if (i === currentIndex) {
                item.style.opacity = "1";
                item.style.filter = "brightness(100%)";
                item.style.transform = "scale(1)";
            } else {
                item.style.opacity = "0.4";
                item.style.filter = "brightness(50%)";
                item.style.transform = "scale(0.95)";
            }
        });
    }

    function moveStage(direction) {
        currentIndex = (currentIndex + direction + items.length) % items.length;
        updateStage();
    }

    // Handle window resizing to keep it centered
    window.addEventListener('resize', updateStage);

    // Initial center
    updateStage();
</script>
