@{
    ViewData["Title"] = "About Us";
}

<div class="relative w-full overflow-hidden text-white font-sans bg-[#020b18] pt-24 pb-20 px-8 md:px-24">
    <!-- Header Section -->
    <div class="max-w-7xl mx-auto mb-16">
        <h1 class="font-['Syne'] font-black text-6xl md:text-[7rem] tracking-tighter uppercase leading-none mb-8">
            Meet<br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-orange-300">Game Garage</span>
        </h1>
        
        <div class="flex flex-col md:flex-row justify-between items-start gap-12 mt-12">
            <p class="text-gray-400 max-w-xl text-lg font-light leading-relaxed">
                I believe that gaming is more than just entertainment; it's a culture, a connection, and a way of life. Game Garage is built to be the ultimate sanctuary for players, uniting cutting-edge design with an unwavering passion for the medium.
            </p>
            <div class="text-sm text-gray-500 max-w-xs font-mono uppercase tracking-widest border-l-2 border-orange-500/30 pl-6 py-2">
                Discover a new way of living your digital adventures. Curated excellence.
            </div>
        </div>
    </div>

    <!-- Main Hero Image -->
    <div class="max-w-7xl mx-auto w-full h-[60vh] md:h-[80vh] rounded-2xl overflow-hidden mb-32 relative group">
        <div class="absolute inset-0 bg-gradient-to-t from-[#020b18] via-transparent to-transparent z-10"></div>
        <img src="/images/Employees.jpeg" alt="Gaming Setup" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
    </div>

    <!-- Inside Section -->
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16 mb-40">
        <div class="lg:col-span-4">
            <h2 class="font-['Syne'] font-bold text-3xl md:text-5xl uppercase tracking-tight text-white/90">Inside<br/><span class="italic text-orange-500">Game Garage</span></h2>
        </div>
        
        <div class="lg:col-span-8 flex flex-col gap-16">
            <!-- Vision -->
            <div class="flex flex-col md:flex-row gap-6 md:gap-16 border-t border-gray-800 pt-8">
                <div class="font-mono text-orange-500/80 font-bold shrink-0">01</div>
                <div class="w-full md:w-1/3 text-2xl font-['Syne'] font-bold text-white/90">Our Vision</div>
                <div class="w-full md:w-2/3 text-gray-400 font-light leading-relaxed">
                    To create the ultimate digital showroom where players can explore, discover, and connect with their next great adventure. We envision a space free from clutter, focusing purely on the artistry of games.
                </div>
            </div>
            <!-- Mission -->
            <div class="flex flex-col md:flex-row gap-6 md:gap-16 border-t border-gray-800 pt-8">
                <div class="font-mono text-orange-500/80 font-bold shrink-0">02</div>
                <div class="w-full md:w-1/3 text-2xl font-['Syne'] font-bold text-white/90">Our Mission</div>
                <div class="w-full md:w-2/3 text-gray-400 font-light leading-relaxed">
                    By merging sleek, modern design principles with dynamic technology, we strive to build a platform that feels like a premium gallery, elevating the games we feature to the masterpieces they are.
                </div>
            </div>
        </div>
    </div>

    <!-- Huge Divider Text -->
    <div class="w-full overflow-hidden whitespace-nowrap border-y border-white/5 py-8 mb-40 bg-[#040c14]">
        <div class="inline-block animate-marquee font-['Bebas_Neue'] text-[8rem] md:text-[12rem] leading-none text-white/5 tracking-wider">
            PASSION • CRAFTSMANSHIP • DESIGN • CURATION • PASSION • CRAFTSMANSHIP • DESIGN
        </div>
    </div>

    <style>
        .animate-marquee {
            animation: marquee 30s linear infinite;
        }
        @@keyframes marquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }
        .accordion-item {
            transition: all 0.3s ease;
        }
        .accordion-content {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.4s ease;
        }
        .accordion-item.active .accordion-content {
            max-height: 200px;
        }
        .accordion-item.active .icon-plus::before {
            transform: rotate(45deg);
        }
    </style>

    <!-- Design & Soul -->
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 mb-40 items-start">
        <div class="flex flex-col gap-12 sticky top-32">
            <h2 class="font-['Syne'] font-bold text-3xl md:text-5xl uppercase tracking-tight text-white/90">Design <span class="text-orange-500">&</span> Soul</h2>
            <div class="w-3/4 aspect-square rounded-2xl overflow-hidden grayscale contrast-125 hover:grayscale-0 transition-all duration-700">
                <img src="https://images.unsplash.com/photo-1550745165-9bc0b252726f?q=80&w=2070&auto=format&fit=crop" class="w-full h-full object-cover" alt="Detail" />
            </div>
        </div>
        
        <div class="flex flex-col border-t border-gray-800">
            <!-- Accordion Items -->
            @foreach (var item in new[] { 
                new { Title = "Curated Selection", Desc = "We handpick every title, focusing on games that push boundaries." },
                new { Title = "Timeless Aesthetics", Desc = "Our interface is designed to stay out of the way, letting the art shine." },
                new { Title = "Detail Craftsmanship", Desc = "Every shadow, every animation, built with painstaking precision." },
                new { Title = "Thoughtful Consistency", Desc = "A unified experience across the entire catalog." },
                new { Title = "Modern Catalog", Desc = "Finding the balance between good games and vibrant game art." }
            })
            {
                <div class="accordion-item border-b border-gray-800 py-6 cursor-pointer group" onclick="this.classList.toggle('active')">
                    <div class="flex justify-between items-center text-xl font-['Syne'] font-medium text-gray-300 group-hover:text-white transition-colors">
                        @item.Title
                        <span class="icon-plus relative w-4 h-4 text-orange-500 transition-transform">
                            <span class="absolute top-1/2 left-0 w-full h-[2px] bg-current -translate-y-1/2 rounded"></span>
                            <span class="absolute top-0 left-1/2 w-[2px] h-full bg-current -translate-x-1/2 rounded"></span>
                        </span>
                    </div>
                    <div class="accordion-content">
                        <p class="pt-4 text-gray-400 font-light pr-12">@item.Desc</p>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Designer Behind The Vision -->
    <div id="socials" class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16 items-center mb-40">
        <div class="lg:col-span-5 order-2 lg:order-1">
            <h2 class="font-['Syne'] font-bold text-3xl md:text-5xl uppercase tracking-tight text-white/90 mb-8 max-w-sm">
                Designer <span class="italic font-light text-gray-400">behind</span> the vision
            </h2>
            <p class="text-gray-400 font-light leading-relaxed mb-8">
                Every line of code and every pixel on this screen was meticulously crafted by a single mind. Bound by a shared passion for elegant, timeless quality, Game Garage represents a singular vision of what a gaming platform should feel like.
            </p>
            <div class="italic text-orange-500 font-['Syne'] text-lg mb-8">
                "Creating an immersive space that fades into the background while the games take center stage."
            </div>

            <!-- Social & Contact Links -->
            <div class="flex flex-col items-start gap-4 pt-4 border-t border-white/5 ">
                <a href="mailto:tim@gamegarage.com" class="group/link flex items-center gap-3 text-gray-400 hover:text-white transition-colors duration-300">
                    <span class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center group-hover/link:border-orange-500/50 group-hover/link:bg-orange-500/10 transition-all duration-300">
                        <i class="fa-solid fa-envelope text-sm"></i>
                    </span>
                    <span class="text-xs font-mono uppercase tracking-widest hidden md:inline">ccs.timotheoche@gmail.com</span>
                </a>
                <a href="https://www.facebook.com/pxdilla.15" target="_blank" class="group/link flex items-center gap-3 text-gray-400 hover:text-white transition-colors duration-300">
                    <span class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center group-hover/link:border-orange-500/50 group-hover/link:bg-orange-500/10 transition-all duration-300">
                        <i class="fa-brands fa-facebook-f text-sm"></i>
                    </span>
                    <span class="text-xs font-mono uppercase tracking-widest hidden md:inline">Tim De Gracia Padilla</span>
                </a>
            </div>
        </div>
        
        <div class="lg:col-span-7 order-1 lg:order-2">
            <!-- Single Portrait as requested -->
            <div class="relative w-full aspect-[4/5] max-w-md mx-auto group overflow-hidden rounded-lg">
                <!-- Using a classy portrait from Unsplash -->
                <img src="/images/TimJobs.png" class="w-full h-full object-cover grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700" alt="Tim - Founder" />
                <div class="absolute bottom-6 left-6 z-10 flex flex-col">
                    <span class="font-['Syne'] font-bold text-2xl text-white">Tim</span>
                    <span class="text-orange-500 font-mono text-sm tracking-widest uppercase">Founder & Creator</span>
                </div>
                <div class="absolute inset-0 bg-gradient-to-t from-[#020b18] via-transparent to-transparent opacity-80 z-0"></div>
            </div>
        </div>
    </div>

    <!-- The Awards (Logos) -->
    <div class="max-w-7xl mx-auto border-t border-gray-800 pt-20 mb-32 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-3">
            <h3 class="font-['Syne'] text-2xl uppercase tracking-widest">The <em class="text-orange-500 font-normal">Art</em> OF <em class="text-orange-500 font-normal">VIBE</em></h3>
        </div>
        <div class="lg:col-span-4 text-gray-400 font-light">
            Game Garage is globally recognized for its timeless simplicity and purpose.
        </div>
        <div class="lg:col-span-5 flex justify-between gap-6 overflow-x-auto opacity-50 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-500">
            <!-- Dummy Award Logos using FontAwesome or SVGs for visual representation -->
            <div class="h-16 w-16 bg-white/5 rounded-full flex items-center justify-center shrink-0 border border-white/10"><i class="fa-solid fa-leaf text-2xl"></i></div>
            <div class="h-16 w-16 bg-white/5 rounded-full flex items-center justify-center shrink-0 border border-white/10"><i class="fa-solid fa-trophy text-2xl"></i></div>
            <div class="h-16 w-16 bg-white/5 rounded-full flex items-center justify-center shrink-0 border border-white/10"><i class="fa-solid fa-star text-2xl"></i></div>
            <div class="h-16 w-16 bg-white/5 rounded-full flex items-center justify-center shrink-0 border border-white/10"><i class="fa-solid fa-medal text-2xl"></i></div>
        </div>
    </div>

    <!-- Bottom Promo Banner -->
    <div class="max-w-screen-2xl mx-auto overflow-hidden rounded-2xl relative mb-12">
        <img src="https://images.unsplash.com/photo-1616588589676-62b3bd4ff6d2?q=80&w=2064&auto=format&fit=crop" class="w-full h-64 md:h-[400px] object-cover opacity-60 mix-blend-screen" alt="Orange Wood Decor" />
        <div class="absolute inset-0 bg-gradient-to-r from-[#020509] via-[#020509]/80 to-transparent"></div>
        <div class="absolute inset-0 p-12 md:p-24 flex flex-col justify-center">
            <div class="font-['Bebas_Neue'] text-5xl md:text-7xl text-white leading-none mb-4 tracking-wide">
                PLAY WITH INTENTION
            </div>
            <p class="text-gray-400 max-w-sm font-light mb-8">
                Every detail matters. We've built an infrastructure designed entirely around presenting the essence of our games.
            </p>
            <div>
                <a asp-controller="Catalog" asp-action="Index" class="inline-flex py-3 px-8 border border-orange-500/50 hover:bg-orange-500 hover:text-white transition-all text-xs tracking-widest uppercase font-bold text-orange-500 rounded">
                    Explore Catalog →
                </a>
            </div>
        </div>
    </div>
</div>
