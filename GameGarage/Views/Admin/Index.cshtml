@{
    ViewData["Title"] = "Dashboard";
    Layout = "_AdminLayout";
}

<div class="p-8">
    <div class="grid grid-cols-4 gap-6 mb-8">
        <div class="bg-orange-600 p-6 rounded-3xl text-white shadow-lg shadow-orange-600/20">
            <p class="text-sm opacity-80">Total Playtime</p>
            <h3 class="text-3xl font-bold mt-1">1,248h</h3>
            <p class="text-xs mt-2">+12% from last week</p>
        </div>
        <div class="bg-[#12161f] p-6 rounded-3xl border border-gray-800">
            <p class="text-sm text-gray-400">Games Owned</p>
            <h3 class="text-3xl font-bold mt-1">84</h3>
            <p class="text-xs text-green-500 mt-2">↑ 3 New items</p>
        </div>
        <div class="bg-[#12161f] p-6 rounded-3xl border border-gray-800">
            <p class="text-sm text-gray-400">Achievements</p>
            <h3 class="text-3xl font-bold mt-1">412</h3>
            <p class="text-xs text-orange-500 mt-2">12 Pending</p>
        </div>
        <div class="bg-[#12161f] p-6 rounded-3xl border border-gray-800">
            <p class="text-sm text-gray-400">Friend Activity</p>
            <h3 class="text-3xl font-bold mt-1">15</h3>
            <p class="text-xs text-blue-400 mt-2">Online now</p>
        </div>
    </div>

    <div class="grid grid-cols-12 gap-6">
        <div class="col-span-8 space-y-6">
            <div class="bg-[#12161f] p-6 rounded-3xl border border-gray-800">
                <h4 class="font-bold mb-6">Gaming Trends</h4>
                <div class="flex items-end justify-between h-48 gap-2">
                    <div class="w-full bg-gray-800 rounded-t-lg h-24"></div>
                    <div class="w-full bg-orange-600 rounded-t-lg h-40"></div>
                    <div class="w-full bg-gray-800 rounded-t-lg h-32"></div>
                    <div class="w-full bg-orange-900 rounded-t-lg h-48"></div>
                    <div class="w-full bg-gray-800 rounded-t-lg h-20"></div>
                    <div class="w-full bg-orange-600 rounded-t-lg h-36"></div>
                    <div class="w-full bg-gray-800 rounded-t-lg h-28"></div>
                </div>
            </div>

            <div class="bg-[#12161f] p-6 rounded-3xl border border-gray-800">
                <div class="flex justify-between items-center mb-6">
                    <h4 class="font-bold">Active Squad</h4>
                    <button class="text-orange-500 text-sm font-medium">+ Invite</button>
                </div>
                <div class="space-y-4">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-blue-500"></div>
                            <div>
                                <p class="text-sm font-bold">Tank_Main</p>
                                <p class="text-xs text-gray-500">Playing: Black Myth: Wukong</p>
                            </div>
                        </div>
                        <span class="px-3 py-1 bg-green-500/10 text-green-500 text-[10px] rounded-full uppercase">In-Game</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-purple-500"></div>
                            <div>
                                <p class="text-sm font-bold">Healer4Life</p>
                                <p class="text-xs text-gray-500">In Menu</p>
                            </div>
                        </div>
                        <span class="px-3 py-1 bg-orange-500/10 text-orange-500 text-[10px] rounded-full uppercase">Away</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-span-4 space-y-6">
            <div class="bg-[#12161f] p-6 rounded-3xl border border-gray-800">
                <h4 class="font-bold mb-6">Recent Releases</h4>
                <div class="space-y-4">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 bg-gray-800 rounded-xl flex-shrink-0"></div>
                        <div class="flex-1">
                            <p class="text-sm font-bold">Elden Ring DLC</p>
                            <p class="text-xs text-gray-500">Release: Jun 2024</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 bg-gray-800 rounded-xl flex-shrink-0"></div>
                        <div class="flex-1">
                            <p class="text-sm font-bold">Dragon's Dogma 2</p>
                            <p class="text-xs text-gray-500">Release: Mar 2024</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-[#12161f] p-6 rounded-3xl border border-gray-800">
                <h4 class="font-bold mb-2 text-center">Black Myth Progress</h4>
                <div class="relative flex justify-center py-6">
                    <div class="w-32 h-32 rounded-full border-8 border-gray-800 border-t-orange-600 flex items-center justify-center">
                        <span class="text-2xl font-bold">74%</span>
                    </div>
                </div>
                <p class="text-xs text-center text-gray-500">Chapter 4: The Spider's Cave</p>
            </div>

            <div class="bg-gradient-to-br from-orange-600 to-orange-900 p-6 rounded-3xl shadow-lg shadow-orange-600/20">
                <p class="text-xs uppercase tracking-widest opacity-80 mb-2">Current Session</p>
                <h2 class="text-4xl font-mono font-bold mb-6">03:14:22</h2>
                <div class="flex gap-2">
                    <button class="flex-1 bg-white/20 py-2 rounded-xl backdrop-blur-sm hover:bg-white/30 transition-all"><i class="fas fa-pause"></i></button>
                    <button class="flex-1 bg-red-500/40 py-2 rounded-xl backdrop-blur-sm hover:bg-red-500/50 transition-all"><i class="fas fa-stop"></i></button>
                </div>
            </div>
        </div>
    </div>
</div>