@model IEnumerable<GameGarage.Models.ViewModels.UserViewModel>

@{
    ViewData["Title"] = "User Management";
    Layout = "_AdminLayout";
}

<div class="p-8">
    <div class="flex justify-between items-center mb-8">
        <div>
            <h1 class="text-3xl font-black text-white tracking-tighter italic uppercase">User Management</h1>
            <p class="text-gray-500 text-sm mt-1">Manage platform access and user accounts</p>
        </div>
    </div>

    <div class="bg-[#12161f] rounded-3xl border border-gray-800 overflow-hidden shadow-2xl shadow-black/50">
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="border-b border-gray-800 bg-white/5">
                        <th class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-gray-500">User</th>
                        <th class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-gray-500">Email</th>
                        <th class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-gray-500 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-800/50">
                    @foreach (var user in Model)
                    {
                        <tr class="group hover:bg-white/5 transition-colors">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-xl bg-orange-600/10 flex items-center justify-center border border-orange-600/20">
                                        <i class="fas fa-user text-orange-500 text-sm"></i>
                                    </div>
                                    <span class="text-sm font-bold text-white group-hover:text-orange-500 transition-colors">@user.UserName</span>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="text-sm text-gray-400">@user.Email</span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex justify-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@user.Id" 
                                       class="p-2 bg-blue-500/10 text-blue-500 hover:bg-blue-500 hover:text-white rounded-lg transition-all border border-blue-500/20">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@user.Id" method="post" 
                                          onsubmit="return confirm('Are you sure you want to delete this user?');" 
                                          class="inline">
                                        <button type="submit" class="p-2 bg-red-500/10 text-red-500 hover:bg-red-500 hover:text-white rounded-lg transition-all border border-red-500/20">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
